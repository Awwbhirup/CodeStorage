{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "Build with gcc",
			"command": "D:\\cpp\\winlibs-x86_64-posix-seh-gcc-14.1.0-mingw-w64ucrt-11.0.1-r1\\mingw64\\bin\\g++.exe",
			"args": [
